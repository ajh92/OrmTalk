@using App.Controllers
@model StopFieldsPartialModel

<div class="border-4 border-black p-4 relative" id="stop-@Model.Index">
    <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-black uppercase tracking-widest">Stop @(Model.Index + 1)</span>
        <button type="button"
                onclick="document.getElementById('stop-@Model.Index').remove()"
                class="px-2 py-0.5 text-xs font-black uppercase bg-red-600 text-white
                       border-2 border-red-600 hover:bg-white hover:text-red-600 transition-colors cursor-pointer">
            ✕
        </button>
    </div>

    <input type="hidden" name="Stops[@Model.Index].SequenceNumber" value="@Model.Stop.SequenceNumber" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div>
            <label class="block text-[10px] font-black uppercase tracking-widest mb-1">Start</label>
            <input type="datetime-local"
                   name="Stops[@Model.Index].Start"
                   value="@Model.Stop.Start"
                   class="w-full border-4 border-black px-2 py-1 text-sm font-bold
                          focus:outline-none focus:border-yellow-400 transition-colors" />
        </div>
        <div>
            <label class="block text-[10px] font-black uppercase tracking-widest mb-1">End</label>
            <input type="datetime-local"
                   name="Stops[@Model.Index].End"
                   value="@Model.Stop.End"
                   class="w-full border-4 border-black px-2 py-1 text-sm font-bold
                          focus:outline-none focus:border-yellow-400 transition-colors" />
        </div>
        <div>
            <label class="block text-[10px] font-black uppercase tracking-widest mb-1">Timezone</label>
            <select name="Stops[@Model.Index].ZoneId"
                    class="w-full border-4 border-black px-2 py-1 text-sm font-bold bg-white
                           focus:outline-none focus:border-yellow-400 transition-colors">
@{
    string[] zones = new[] { "America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles", "America/Phoenix", "America/Anchorage", "Pacific/Honolulu", "UTC" };
}
@foreach (string zone in zones)
{
                    <option value="@zone" selected="@(zone == Model.Stop.ZoneId)">@zone</option>
}
            </select>
        </div>
    </div>
</div>
